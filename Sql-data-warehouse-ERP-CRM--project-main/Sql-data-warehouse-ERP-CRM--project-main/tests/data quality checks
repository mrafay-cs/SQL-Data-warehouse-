-- Validating if Sales has any nulls or 0, quantity has nulls or 0, price has any nulls or 0, nd if sales amount is not matching when multiplying
-- quantity with price 
-- If sales is null or 0 then calculate sales with quantity * price
-- if quantity is null or 0 the calculate quantity with sales/price
-- if price is null or 0 then calculate price with sales/quantity

SELECT
Sales_SaleAmount As Old,
Sales_Price As OldPrice,
Sales_Quantity As oldQnty
FROM bronze.crm_sales_info
WHERE Sales_SaleAmount IS NULL OR Sales_Quantity IS NULL OR Sales_Price IS NULL
OR Sales_SaleAmount <=0 OR Sales_Quantity <=0 OR Sales_Price <= 0 OR
Sales_SaleAmount != Sales_Quantity * Sales_Price                                                      

